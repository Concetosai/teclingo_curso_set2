   {
     "buildCommand": "npm run build",
     "outputDirectory": "dist",
     "framework": "vite",
     "functions": {
       "api/index.py": {
         "maxDuration": 30
       }
     },
     "rewrites": [
       { "source": "/api/(.*)", "destination": "/api/index.py" },
       { "source": "/(.*)", "destination": "/index.html" }
     ]
   }